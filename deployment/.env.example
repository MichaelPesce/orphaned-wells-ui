# Docker Compose project naming
COMPOSE_PROJECT_NAME=orphaned-wells-dev

# Backend runtime mode.
# auto uses a sibling backend repo when it exists, otherwise it pulls BACKEND_IMAGE.
# image always pulls BACKEND_IMAGE.
# source requires BACKEND_DIR to exist and builds the backend locally.
BACKEND_MODE=auto
BACKEND_IMAGE=michaelpescelbl/orphaned-wells-ui-server:latest
BACKEND_DEV_IMAGE=orphaned-wells-ui-server-dev

# Optional sibling backend repository. This path is relative to orphaned-wells-ui/deployment.
BACKEND_DIR=../../orphaned-wells-ui-server
BACKEND_GIT_URL=https://github.com/CATALOG-Historic-Records/orphaned-wells-ui-server.git
BACKEND_AUTO_CLONE=false

# Host ports. MongoDB uses 27018 by default to avoid colliding with a local MongoDB on 27017.
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=8001
MONGODB_HOST_PORT=27018

# Frontend runtime variables
REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_ENVIRONMENT=development
REACT_APP_STATE=IL
REACT_APP_COLLABORATOR=isgs
REACT_APP_CLIENT_ID=
REACT_APP_GOOGLE_CLIENTID=
GOOGLE_REFRESH_TOKEN=

# Backend app variables
ENVIRONMENT=development
COLLABORATOR=isgs
LOCATION=us
DB_NAME=isgs
REQUIRE_AUTH=false
USE_DB_PROCESSORS=true
STORAGE_BACKEND=local
DOCUMENT_AI_BACKEND=google
DOCUMENT_AI_URL=
DOCUMENT_AI_TIMEOUT=60

# Mongo dump initialization.
# Runs automatically only when the MongoDB volume is first created.
MONGO_INIT_SAMPLE_DUMP=true
MONGO_DUMP_SOURCE_DB=isgs

# Optional Google Cloud / OAuth settings. Leave blank for local auth-disabled development.
PROJECT_ID=
STORAGE_SERVICE_KEY=
STORAGE_BUCKET_NAME=
token_uri=
client_id=
client_secret=
APIKEY=

# Optional backend diagnostics
MEMORY_PROFILE=false
PROCESS_IMAGE_IN_SUBPROCESS=false
